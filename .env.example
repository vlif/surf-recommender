# Токен Stormglass API (https://stormglass.io)
STORMGLASS_TOKEN=your_stormglass_token_here

# Ключ Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram бот
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=@surfing_in_portugal  # опционально, это значение по умолчанию

# Модель Claude (опционально, по умолчанию claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Планировщик (опционально, используется только с флагом --daemon)
# CRON_SCHEDULE=0 6 * * *   # каждый день в 06:00 по CRON_TIMEZONE
# CRON_TIMEZONE=Europe/Lisbon
